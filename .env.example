APP_NAME="Execution Workspace"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_PORT=4173
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
SPARK_MASTER_PORT=7077
SPARK_UI_PORT=8081
DATABASE_URL=postgresql+asyncpg://workspace:workspace@postgres:5432/workspace
EXECUTION_TIMEOUT_MS=60000
EXECUTION_MAX_ROWS=1000
EXECUTION_DEFAULT_LIMIT=100
UPLOAD_ENABLED=true
UPLOAD_MAX_FILE_SIZE_MB=100
RUNTIME_DATASOURCE_ALLOW_CREATION=true
RULE_ENGINE_ENABLED=false
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=datasets
LOCAL_STORAGE_PATH=/app/data/storage
UPLOAD_PATH=/app/data/uploads
APP_CREDENTIAL_KEY=change-me-with-32-byte-base64-key
CONFIG_FILE=/app/config/application.yml
